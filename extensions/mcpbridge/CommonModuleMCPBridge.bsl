// Общий модуль «МСПМост» — бизнес-логика моста между MCP-сервером и 1С.
//
// Назначение: вызывать из обработчиков HTTP-сервиса MCPBridge.
// Сюда не должны попадать ни HTTPСервисОтвет, ни манипуляции с
// заголовками — это задача HTTP-обработчиков.
//
// Имя модуля «МСПМост» намеренно по-русски: расширение пишется под
// типовую и должно выглядеть однородно с остальной конфигурацией.
//
// Свойства модуля: Серверный = Истина, Клиент(управляемое
// приложение) = Ложь, ВнешнееСоединение = Истина, Глобальный = Ложь,
// Привилегированный режим = Ложь.

#Если Сервер Или ВнешнееСоединение Тогда

// Возвращает структуру со статусом сервера 1С.
//
// Параметры: нет.
//
// Возвращаемое значение: Структура — { ok, version, locale, ts, user }.

Функция СтатусСервера() Экспорт

    ИнфоПлатформы = ИнформацияПлатформы();
    ТекущийПользователь = ПользователиИнформационнойБазы.ТекущийПользователь();

    Структура = Новый Структура;
    Структура.Вставить("ok", Истина);
    Структура.Вставить("version", ИнфоПлатформы.ВерсияПриложения);
    Структура.Вставить("locale", ИнфоПлатформы.ВерсияОС);
    Структура.Вставить("ts", ТекущаяДатаСеанса());
    Структура.Вставить("user", ?(ТекущийПользователь = Неопределено,
        "anonymous", ТекущийПользователь.Имя));

    Возврат Структура;

КонецФункции

// Выполняет язык запросов и возвращает список строк.
//
// Параметры:
//   Текст — Строка — язык запросов 1С.
//   Параметры — Структура — параметры запроса (имя→значение).
//
// Возвращаемое значение: Структура — { ok, rows: [Структура,…], count }.

Функция ВыполнитьЗапрос(Знач Текст, Знач Параметры) Экспорт

    Запрос = Новый Запрос;
    Запрос.Текст = Текст;

    Если ТипЗнч(Параметры) = Тип("Структура") Тогда
        Для Каждого Свойство Из Параметры Цикл
            Запрос.УстановитьПараметр(Свойство.Ключ, Свойство.Значение);
        КонецЦикла;
    КонецЕсли;

    Выборка = Запрос.Выполнить().Выбрать();
    Строки = Новый Массив;

    Пока Выборка.Следующий() Цикл
        Строка = Новый Структура;
        Для Каждого Колонка Из Запрос.Выполнить().Колонки Цикл
            Строка.Вставить(Колонка.Имя,
                СериализоватьЗначение(Выборка[Колонка.Имя]));
        КонецЦикла;
        Строки.Добавить(Строка);
    КонецЦикла;

    Результат = Новый Структура;
    Результат.Вставить("ok", Истина);
    Результат.Вставить("rows", Строки);
    Результат.Вставить("count", Строки.Количество());
    Возврат Результат;

КонецФункции

// Выполняет произвольный 1С-код. Всегда оборачивает в транзакцию.
// При ТолькоЧтение=Истина транзакция откатывается; при Ложь —
// фиксируется, но это требует подтверждения авторизации (scope).
//
// Параметры:
//   Код — Строка — код на встроенном языке 1С.
//   ТолькоЧтение — Булево — Истина: всегда откат; Ложь: фиксировать.
//
// Возвращаемое значение: Структура — { ok, result, messages, committed }.

Функция ВыполнитьКод(Знач Код, Знач ТолькоЧтение) Экспорт

    Сообщения = Новый Массив;
    Результат = Неопределено;
    Зафиксировано = Ложь;

    НачатьТранзакцию();
    Попытка
        // Контекст для исполняемого кода: «Результат» — куда писать
        // выходное значение, «Сообщения» — куда добавлять диагностику.
        ВыполняемыйКонтекст = Новый Структура("Результат, Сообщения",
            Результат, Сообщения);

        Выполнить("Результат = " + Код); // одиночное выражение
        Результат = ВыполняемыйКонтекст.Результат;

        Если ТолькоЧтение Тогда
            ОтменитьТранзакцию();
        Иначе
            ЗафиксироватьТранзакцию();
            Зафиксировано = Истина;
        КонецЕсли;

    Исключение
        ОтменитьТранзакцию();
        ВызватьИсключение;
    КонецПопытки;

    Ответ = Новый Структура;
    Ответ.Вставить("ok", Истина);
    Ответ.Вставить("result", СериализоватьЗначение(Результат));
    Ответ.Вставить("messages", Сообщения);
    Ответ.Вставить("committed", Зафиксировано);
    Возврат Ответ;

КонецФункции

// Чтение JSON-тела входящего HTTP-запроса в структуру.

Функция ПрочитатьТелоJSON(Знач Запрос) Экспорт

    Чтение = Новый ЧтениеJSON;
    Чтение.УстановитьСтроку(Запрос.ПолучитьТелоКакСтроку());
    Возврат ПрочитатьJSON(Чтение, Истина);

КонецФункции

// Сериализация структуры/массива в строку JSON.

Функция JSON(Знач Объект) Экспорт

    Запись = Новый ЗаписьJSON;
    Запись.УстановитьСтроку();
    ЗаписатьJSON(Запись, Объект);
    Возврат Запись.Закрыть();

КонецФункции

// Унифицированный JSON-ответ об ошибке. Не меняет код HTTP-ответа,
// но всегда устанавливает ok=false и поля code/message — клиент должен
// сам решать, фатально это или повторить.

Функция ОшибкаОтвет(Ответ, Знач КодОшибки, Знач Сообщение) Экспорт

    Тело = Новый Структура;
    Тело.Вставить("ok", Ложь);
    Тело.Вставить("code", КодОшибки);
    Тело.Вставить("message", Сообщение);
    Ответ.УстановитьТелоИзСтроки(JSON(Тело), КодировкаТекста.UTF8);
    Возврат Ответ;

КонецФункции

// === Внутренние утилиты ====================================================

// Привести значение к JSON-сериализуемому виду. Ссылки → строка
// представления, Дата → ISO-формат, всё остальное — как есть.
Функция СериализоватьЗначение(Знач Значение)

    Если Значение = Неопределено Тогда
        Возврат Неопределено;
    КонецЕсли;

    ТипЗначения = ТипЗнч(Значение);

    Если Метаданные.НайтиПоТипу(ТипЗначения) <> Неопределено Тогда
        // Это ссылка
        Возврат Строка(Значение);
    КонецЕсли;

    Если ТипЗначения = Тип("Дата") Тогда
        Возврат Формат(Значение, "ДФ='yyyy-MM-ddTHH:mm:ss'");
    КонецЕсли;

    Возврат Значение;

КонецФункции

#КонецЕсли
