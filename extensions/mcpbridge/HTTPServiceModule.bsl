// HTTP-сервис «MCPBridge» — точка входа в работающую 1С из MCP-сервера.
//
// Этот модуль — обработчики методов HTTP-сервиса. Бизнес-логика
// вынесена в общий модуль «МСПМост»: так её удобнее тестировать
// и не зависеть от запросной обвязки.
//
// Маршруты:
//   GET  /mcpbridge/status          — health и описание сервера
//   POST /mcpbridge/query           — выполнить язык запросов
//   POST /mcpbridge/eval            — выполнить произвольный код в транзакции с откатом
//
// Безопасность: HTTP-сервис должен быть опубликован под отдельным
// техническим пользователем с минимальными правами на чтение.
// /eval — потенциально опасен; см. README раздел «Защита».

#Если Сервер Тогда

// === GET /mcpbridge/status =================================================

Функция StatusGet(Запрос) Экспорт

    Ответ = Новый HTTPСервисОтвет(200);
    Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");

    Полезное = МСПМост.СтатусСервера();
    Ответ.УстановитьТелоИзСтроки(МСПМост.JSON(Полезное), КодировкаТекста.UTF8);

    Возврат Ответ;

КонецФункции

// === POST /mcpbridge/query =================================================
// Тело запроса (JSON): { "text": "ВЫБРАТЬ ...", "params": { "ИмяПараметра": Значение, ... } }
// Ответ:               { "ok": true, "rows": [ { "Поле1": ..., }, ... ], "count": N }

Функция QueryPost(Запрос) Экспорт

    Ответ = Новый HTTPСервисОтвет(200);
    Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");

    Попытка
        Тело = МСПМост.ПрочитатьТелоJSON(Запрос);
        Текст = ?(Тело.Свойство("text"), Тело.text, "");
        Параметры = ?(Тело.Свойство("params"), Тело.params, Новый Структура);

        Если ПустаяСтрока(Текст) Тогда
            Возврат МСПМост.ОшибкаОтвет(Ответ, "MISSING_TEXT", "поле text пустое");
        КонецЕсли;

        Результат = МСПМост.ВыполнитьЗапрос(Текст, Параметры);
        Ответ.УстановитьТелоИзСтроки(МСПМост.JSON(Результат), КодировкаТекста.UTF8);

    Исключение
        Возврат МСПМост.ОшибкаОтвет(Ответ, "QUERY_FAILED", ОписаниеОшибки());
    КонецПопытки;

    Возврат Ответ;

КонецФункции

// === POST /mcpbridge/eval ==================================================
// Тело запроса (JSON):
//   {
//     "code": "Сообщение = Новый СообщениеПользователю; ...",
//     "read_only": true
//   }
// Любой запрос исполняется внутри НачатьТранзакцию()/ОтменитьТранзакцию()
// при read_only=true — изменения откатываются ВСЕГДА. read_only=false
// делает Зафиксировать(), но требует scope «execute:write» (см. README).
//
// Ответ:
//   { "ok": true, "result": <любое JSON-сериализуемое>,
//     "messages": [ "...", "..." ],
//     "committed": false }

Функция EvalPost(Запрос) Экспорт

    Ответ = Новый HTTPСервисОтвет(200);
    Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");

    Попытка
        Тело = МСПМост.ПрочитатьТелоJSON(Запрос);
        Код = ?(Тело.Свойство("code"), Тело.code, "");
        ТолькоЧтение = ?(Тело.Свойство("read_only"), Тело.read_only, Истина);

        Если ПустаяСтрока(Код) Тогда
            Возврат МСПМост.ОшибкаОтвет(Ответ, "MISSING_CODE", "поле code пустое");
        КонецЕсли;

        Результат = МСПМост.ВыполнитьКод(Код, ТолькоЧтение);
        Ответ.УстановитьТелоИзСтроки(МСПМост.JSON(Результат), КодировкаТекста.UTF8);

    Исключение
        Возврат МСПМост.ОшибкаОтвет(Ответ, "EVAL_FAILED", ОписаниеОшибки());
    КонецПопытки;

    Возврат Ответ;

КонецФункции

#КонецЕсли
