        {"name": "ЗначениеВСтрокуВнутр", "name_en": "ValueToStringInternal", "description": "Преобразует значение во внутреннее строковое представление", "parameters": [{"name": "Значение", "types": ["Произвольный"], "required": true}], "return_types": ["Строка"], "category": "type"},
        {"name": "ЗначениеИзСтрокиВнутр", "name_en": "ValueFromStringInternal", "description": "Восстанавливает значение из внутреннего представления", "parameters": [{"name": "Строка", "types": ["Строка"], "required": true}], "return_types": ["Произвольный"], "category": "type"},
        {"name": "XMLСтрока", "name_en": "XMLString", "description": "Преобразует значение в XML-строку", "parameters": [{"name": "Значение", "types": ["Произвольный"], "required": true}], "return_types": ["Строка"], "category": "type"},
        {"name": "XMLЗначение", "name_en": "XMLValue", "description": "Восстанавливает значение из XML-строки", "parameters": [{"name": "Тип", "types": ["Тип"], "required": true}, {"name": "Строка", "types": ["Строка"], "required": true}], "return_types": ["Произвольный"], "category": "type"}
      ]
    },
    {
      "name": "Общие функции",
      "name_en": "Common functions",
      "methods": [
