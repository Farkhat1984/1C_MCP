    {
      "id": "movement.posting_full",
      "name": "Full Document Posting Handler",
      "name_ru": "Полный обработчик проведения",
      "description": "Complete posting handler with multiple registers",
      "description_ru": "Полный обработчик проведения с несколькими регистрами",
      "category": "movement",
      "template_code": "Процедура ОбработкаПроведения(Отказ, РежимПроведения)\n\t\n\t// Инициализация движений\n\tДвижения.${RegisterName1}.Записывать = Истина;\n\t{{#if HasRegister2}}\n\tДвижения.${RegisterName2}.Записывать = Истина;\n\t{{/if}}\n\t\n\t// Запрос данных\n\tЗапрос = Новый Запрос;\n\tЗапрос.Текст = \n\t\"ВЫБРАТЬ\n\t|\t${QueryFields}\n\t|ИЗ\n\t|\t${QuerySource}\n\t|ГДЕ\n\t|\t${QuerySource}.Ссылка = &Ссылка\";\n\t\n\tЗапрос.УстановитьПараметр(\"Ссылка\", Ссылка);\n\t\n\tРезультат = Запрос.Выполнить();\n\tВыборка = Результат.Выбрать();\n\t\n\tПока Выборка.Следующий() Цикл\n\t\t\n\t\t// Движение по регистру ${RegisterName1}\n\t\tДвижение = Движения.${RegisterName1}.Добавить();\n\t\tДвижение.ВидДвижения = ${MovementType1};\n\t\tДвижение.Период = Дата;\n\t\t${Movement1Code}\n\t\t\n\t\t{{#if HasRegister2}}\n\t\t// Движение по регистру ${RegisterName2}\n\t\tДвижение2 = Движения.${RegisterName2}.Добавить();\n\t\tДвижение2.ВидДвижения = ${MovementType2};\n\t\tДвижение2.Период = Дата;\n\t\t${Movement2Code}\n\t\t{{/if}}\n\t\t\n\tКонецЦикла;\n\t\nКонецПроцедуры",
      "placeholders": [
        {
          "name": "RegisterName1",
          "display_name": "Регистр 1",
          "type": "metadata_name",
          "required": true
        },
        {
          "name": "MovementType1",
          "display_name": "Тип движения 1",
          "type": "string",
          "required": true,
          "allowed_values": ["ВидДвиженияНакопления.Приход", "ВидДвиженияНакопления.Расход"]
        },
        {
          "name": "Movement1Code",
          "display_name": "Код движения 1",
          "type": "code_block",
          "required": true
        },
        {
          "name": "HasRegister2",
          "display_name": "Второй регистр",
          "type": "boolean",
          "required": false,
          "default_value": "false"
        },
        {
          "name": "RegisterName2",
          "display_name": "Регистр 2",
          "type": "metadata_name",
          "required": false
        },
        {
          "name": "MovementType2",
          "display_name": "Тип движения 2",
          "type": "string",
          "required": false
        },
        {
          "name": "Movement2Code",
          "display_name": "Код движения 2",
          "type": "code_block",
          "required": false
        },
        {
          "name": "QueryFields",
          "display_name": "Поля запроса",
          "type": "string",
          "required": true
        },
        {
          "name": "QuerySource",
          "display_name": "Источник запроса",
          "description": "Таблица источника (например, Документ.ПриходТовара.Товары)",
          "type": "table_name",
          "required": true
        }
      ],
      "tags": ["posting", "проведение", "документ", "полный обработчик"],
      "use_cases": ["Проведение документа", "Несколько регистров"],
      "applicable_module_types": ["ObjectModule"]
    },
    {
      "id": "movement.control_balance",
      "name": "Balance Control in Posting",
      "name_ru": "Контроль остатков при проведении",
      "description": "Balance control code for document posting",
      "description_ru": "Код контроля остатков при проведении документа",
      "category": "movement",
      "template_code": "// Контроль остатков\nЕсли РежимПроведения = РежимПроведенияДокумента.Оперативный Тогда\n\t\n\t// Запрос остатков\n\tЗапросОстатков = Новый Запрос;\n\tЗапросОстатков.Текст = \n\t\"ВЫБРАТЬ\n\t|\tОстатки.${Dimension} КАК ${Dimension},\n\t|\tОстатки.${Resource}Остаток КАК Остаток\n\t|ИЗ\n\t|\tРегистрНакопления.${RegisterName}.Остатки(\n\t|\t\t&МоментВремени,\n\t|\t\t${Dimension} В (&Список${Dimension})) КАК Остатки\";\n\t\n\tЗапросОстатков.УстановитьПараметр(\"МоментВремени\", \n\t\tНовый Граница(МоментВремени(), ВидГраницы.Включая));\n\tЗапросОстатков.УстановитьПараметр(\"Список${Dimension}\", \n\t\t${TabularSection}.ВыгрузитьКолонку(\"${Dimension}\"));\n\t\n\tРезультатОстатков = ЗапросОстатков.Выполнить();\n\tВыборкаОстатков = РезультатОстатков.Выбрать();\n\t\n\tПока ВыборкаОстатков.Следующий() Цикл\n\t\t\n\t\t// Поиск требуемого количества\n\t\tНайденныеСтроки = ${TabularSection}.НайтиСтроки(\n\t\t\tНовый Структура(\"${Dimension}\", ВыборкаОстатков.${Dimension}));\n\t\t\n\t\tТребуется = 0;\n\t\tДля Каждого Строка Из НайденныеСтроки Цикл\n\t\t\tТребуется = Требуется + Строка.${Resource};\n\t\tКонецЦикла;\n\t\t\n\t\tЕсли ВыборкаОстатков.Остаток < Требуется Тогда\n\t\t\t\n\t\t\tСообщение = Новый СообщениеПользователю;\n\t\t\tСообщение.Текст = СтрШаблон(\n\t\t\t\t\"Недостаточно остатков %1: есть %2, требуется %3\",\n\t\t\t\tВыборкаОстатков.${Dimension},\n\t\t\t\tВыборкаОстатков.Остаток,\n\t\t\t\tТребуется);\n\t\t\tСообщение.Сообщить();\n\t\t\t\n\t\t\tОтказ = Истина;\n\t\t\t\n\t\tКонецЕсли;\n\t\t\n\tКонецЦикла;\n\t\nКонецЕсли;",
      "placeholders": [
        {
          "name": "RegisterName",
          "display_name": "Имя регистра",
          "type": "metadata_name",
          "required": true,
          "metadata_type": "AccumulationRegister"
        },
        {
          "name": "Dimension",
          "display_name": "Измерение",
          "description": "Измерение для контроля (например, Номенклатура)",
          "type": "identifier",
          "required": true
        },
        {
          "name": "Resource",
          "display_name": "Ресурс",
          "description": "Ресурс для контроля (например, Количество)",
          "type": "identifier",
          "required": true
        },
        {
          "name": "TabularSection",
          "display_name": "Табличная часть",
          "description": "Табличная часть документа",
          "type": "identifier",
          "required": true,
          "default_value": "Товары"
        }
      ],
      "tags": ["balance", "control", "контроль остатков", "оперативное проведение"],
      "use_cases": ["Контроль остатков", "Оперативное проведение"]
    }
  ]
