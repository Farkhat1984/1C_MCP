      "id": "query.select_simple",
      "name": "Simple SELECT",
      "name_ru": "Простая выборка",
      "description": "Basic SELECT query from a single table",
      "description_ru": "Базовый запрос SELECT из одной таблицы",
      "category": "query",
      "template_code": "ВЫБРАТЬ\n\t${Fields}\nИЗ\n\t${TableName} КАК ${Alias}{{#if HasCondition}}\nГДЕ\n\t${Condition}{{/if}}",
      "placeholders": [
        {
          "name": "Fields",
          "display_name": "Поля",
          "description": "Список полей для выборки",
          "type": "string",
          "required": true,
          "default_value": "*"
        },
        {
          "name": "TableName",
          "display_name": "Таблица",
          "description": "Имя таблицы (например, Справочник.Номенклатура)",
          "type": "table_name",
          "required": true
        },
        {
          "name": "Alias",
          "display_name": "Псевдоним",
          "description": "Псевдоним таблицы",
          "type": "identifier",
          "required": true,
          "default_value": "Т"
        },
        {
          "name": "HasCondition",
          "display_name": "Есть условие",
          "description": "Добавить секцию WHERE",
          "type": "boolean",
          "required": false,
          "default_value": "false"
        },
        {
          "name": "Condition",
          "display_name": "Условие",
          "description": "Условие WHERE",
          "type": "condition",
          "required": false
        }
      ],
      "tags": ["select", "выборка", "простой", "базовый"],
      "use_cases": ["Получение данных из справочника", "Базовая выборка"],
      "examples": [
        {
          "description": "Выборка всех товаров",
          "values": {
            "Fields": "Ссылка, Код, Наименование",
            "TableName": "Справочник.Номенклатура",
            "Alias": "Товары"
          },
          "result_preview": "ВЫБРАТЬ\n\tСсылка, Код, Наименование\nИЗ\n\tСправочник.Номенклатура КАК Товары"
        }
      ]
    },
