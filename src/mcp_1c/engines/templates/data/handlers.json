          "default_value": "// Ваш код здесь"
        }
      ],
      "tags": ["handler", "undo_posting", "ОбработкаУдаленияПроведения", "отмена проведения"],
      "use_cases": ["Отмена проведения", "Очистка связанных данных"],
      "applicable_module_types": ["ObjectModule"]
    },
    {
      "id": "handler.before_delete",
      "name": "BeforeDelete Event Handler",
      "name_ru": "Обработчик ПередУдалением",
      "description": "Handler for BeforeDelete event",
      "description_ru": "Обработчик события ПередУдалением",
      "category": "handler",
      "template_code": "Процедура ПередУдалением(Отказ)\n\t\n\t{{#if CheckReferences}}\n\t// Проверка ссылок на объект\n\tПоискСсылок = Новый Массив;\n\tПоискСсылок.Добавить(Ссылка);\n\t\n\tНайденныеСсылки = НайтиПоСсылкам(ПоискСсылок);\n\tЕсли НайденныеСсылки.Количество() > 0 Тогда\n\t\tСообщениеПользователю = Новый СообщениеПользователю;\n\t\tСообщениеПользователю.Текст = \"Невозможно удалить объект, на него есть ссылки\";\n\t\tСообщениеПользователю.Сообщить();\n\t\tОтказ = Истина;\n\t\tВозврат;\n\tКонецЕсли;\n\t{{/if}}\n\t\n\t${CustomCode}\n\t\nКонецПроцедуры",
      "placeholders": [
        {
          "name": "CheckReferences",
          "display_name": "Проверка ссылок",
          "description": "Добавить проверку ссылок",
          "type": "boolean",
          "required": false,
          "default_value": "true"
        },
        {
          "name": "CustomCode",
          "display_name": "Дополнительный код",
          "type": "code_block",
          "required": false,
          "default_value": "// Ваш код здесь"
        }
      ],
      "tags": ["handler", "before_delete", "ПередУдалением", "удаление", "проверка"],
      "use_cases": ["Контроль удаления", "Проверка ссылок"],
      "applicable_module_types": ["ObjectModule"]
    },
    {
      "id": "handler.filling_check",
      "name": "FillingCheck Event Handler",
      "name_ru": "Обработчик ОбработкаПроверкиЗаполнения",
      "description": "Handler for FillingCheck event",
      "description_ru": "Обработчик события ОбработкаПроверкиЗаполнения",
      "category": "handler",
      "template_code": "Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)\n\t\n\t{{#if ExcludeFields}}\n\t// Исключение реквизитов из проверки\n\tИндекс = ПроверяемыеРеквизиты.Найти(\"${ExcludedField}\");\n\tЕсли Индекс <> Неопределено Тогда\n\t\tПроверяемыеРеквизиты.Удалить(Индекс);\n\tКонецЕсли;\n\t{{/if}}\n\t\n\t{{#if CustomValidation}}\n\t// Дополнительная проверка\n\t${ValidationCode}\n\t{{/if}}\n\t\nКонецПроцедуры",
      "placeholders": [
        {
          "name": "ExcludeFields",
          "display_name": "Исключить поля",
          "type": "boolean",
          "required": false,
          "default_value": "false"
        },
        {
          "name": "ExcludedField",
          "display_name": "Исключаемое поле",
          "type": "identifier",
          "required": false
        },
        {
          "name": "CustomValidation",
          "display_name": "Доп. валидация",
          "type": "boolean",
          "required": false,
          "default_value": "false"
        },
        {
          "name": "ValidationCode",
          "display_name": "Код валидации",
          "type": "code_block",
          "required": false
        }
      ],
      "tags": ["handler", "filling_check", "ОбработкаПроверкиЗаполнения", "проверка", "валидация"],
      "use_cases": ["Проверка заполнения", "Условная проверка"],
      "applicable_module_types": ["ObjectModule"]
    },
    {
      "id": "handler.on_copy",
      "name": "OnCopy Event Handler",
      "name_ru": "Обработчик ПриКопировании",
      "description": "Handler for OnCopy event",
      "description_ru": "Обработчик события ПриКопировании",
      "category": "handler",
      "template_code": "Процедура ПриКопировании(ОбъектКопирования)\n\t\n\t// Очистка полей, которые не должны копироваться\n\t{{#if ClearFields}}\n\t${FieldName} = ${DefaultValue};\n\t{{/if}}\n\t\n\t{{#if ClearTabularSection}}\n\t// Очистка табличной части\n\t${TabularSectionName}.Очистить();\n\t{{/if}}\n\t\n\t${CustomCode}\n\t\nКонецПроцедуры",
