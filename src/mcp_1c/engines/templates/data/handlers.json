          "display_name": "Настройка видимости",
          "type": "boolean",
          "required": false,
          "default_value": "false"
        },
        {
          "name": "VisibilityCode",
          "display_name": "Код видимости",
          "type": "code_block",
          "required": false
        },
        {
          "name": "FillLists",
          "display_name": "Заполнить списки",
          "type": "boolean",
          "required": false,
          "default_value": "false"
        },
        {
          "name": "ListsCode",
          "display_name": "Код списков",
          "type": "code_block",
          "required": false
        },
        {
          "name": "CustomCode",
          "display_name": "Дополнительный код",
          "type": "code_block",
          "required": false,
          "default_value": "// Ваш код здесь"
        }
      ],
      "tags": ["form", "handler", "ПриСозданииНаСервере", "форма", "создание"],
      "use_cases": ["Инициализация формы", "Настройка видимости", "Заполнение списков"],
      "applicable_module_types": ["FormModule"]
    }
  ]
}
