{
  "templates": [
    {
      "id": "handler.before_write",
      "name": "BeforeWrite Event Handler",
      "name_ru": "Обработчик ПередЗаписью",
      "description": "Handler for BeforeWrite event of catalog/document",
      "description_ru": "Обработчик события ПередЗаписью справочника/документа",
      "category": "handler",
      "template_code": "Процедура ПередЗаписью(Отказ)\n\t\n\t// Проверка заполнения обязательных полей\n\t{{#if CheckRequiredFields}}\n\tЕсли НЕ ЗначениеЗаполнено(${RequiredField}) Тогда\n\t\tСообщениеПользователю = Новый СообщениеПользователю;\n\t\tСообщениеПользователю.Текст = \"Не заполнено поле '${RequiredFieldName}'\";\n\t\tСообщениеПользователю.Поле = \"${RequiredField}\";\n\t\tСообщениеПользователю.УстановитьДанные(ЭтотОбъект);\n\t\tСообщениеПользователю.Сообщить();\n\t\tОтказ = Истина;\n\t\tВозврат;\n\tКонецЕсли;\n\t{{/if}}\n\t\n\t${CustomCode}\n\t\nКонецПроцедуры",
      "placeholders": [
        {
          "name": "CheckRequiredFields",
          "display_name": "Проверка обязательных",
          "description": "Добавить проверку обязательных полей",
          "type": "boolean",
          "required": false,
          "default_value": "false"
        },
        {
          "name": "RequiredField",
          "display_name": "Обязательное поле",
          "description": "Имя обязательного поля",
          "type": "identifier",
          "required": false
        },
        {
          "name": "RequiredFieldName",
          "display_name": "Название поля",
          "description": "Отображаемое название поля",
          "type": "string",
          "required": false
        },
        {
          "name": "CustomCode",
          "display_name": "Дополнительный код",
          "description": "Пользовательский код обработчика",
          "type": "code_block",
          "required": false,
          "default_value": "// Ваш код здесь"
        }
      ],
      "tags": ["handler", "before_write", "ПередЗаписью", "событие", "проверка"],
      "use_cases": ["Валидация данных", "Проверка перед записью", "Заполнение полей"],
      "applicable_module_types": ["ObjectModule"],
      "examples": [
        {
          "description": "Проверка заполнения контрагента",
          "values": {
            "CheckRequiredFields": "true",
            "RequiredField": "Контрагент",
            "RequiredFieldName": "Контрагент",
            "CustomCode": "// Дополнительные проверки"
          }
        }
      ]
    },
    {
      "id": "handler.on_write",
      "name": "OnWrite Event Handler",
      "name_ru": "Обработчик ПриЗаписи",
      "description": "Handler for OnWrite event",
      "description_ru": "Обработчик события ПриЗаписи",
      "category": "handler",
      "template_code": "Процедура ПриЗаписи(Отказ)\n\t\n\t{{#if UpdateRelated}}\n\t// Обновление связанных данных\n\tЕсли НЕ Отказ Тогда\n\t\t${UpdateCode}\n\tКонецЕсли;\n\t{{/if}}\n\t\n\t${CustomCode}\n\t\nКонецПроцедуры",
      "placeholders": [
        {
