    {
      "id": "handler.presentation_get",
      "name": "PresentationGet Event Handler",
      "name_ru": "Обработчик ОбработкаПолученияПредставления",
      "description": "Handler for PresentationGet event",
      "description_ru": "Обработчик события ОбработкаПолученияПредставления",
      "category": "handler",
      "template_code": "Процедура ОбработкаПолученияПредставления(Данные, Представление, СтандартнаяОбработка)\n\t\n\tСтандартнаяОбработка = Ложь;\n\t\n\t{{#if UseCode}}\n\tПредставление = СтрШаблон(\"[%1] %2\", Данные.Код, Данные.Наименование);\n\t{{/if}}\n\t{{#if UseCustomFormat}}\n\tПредставление = ${FormatExpression};\n\t{{/if}}\n\t\nКонецПроцедуры",
      "placeholders": [
        {
          "name": "UseCode",
          "display_name": "Использовать код",
          "description": "Включить код в представление",
          "type": "boolean",
          "required": false,
          "default_value": "true"
        },
        {
          "name": "UseCustomFormat",
          "display_name": "Свой формат",
          "type": "boolean",
          "required": false,
          "default_value": "false"
        },
        {
          "name": "FormatExpression",
          "display_name": "Выражение формата",
          "type": "string",
          "required": false
        }
      ],
      "tags": ["handler", "presentation", "ОбработкаПолученияПредставления", "представление"],
      "use_cases": ["Кастомное представление", "Формат отображения"],
      "applicable_module_types": ["ManagerModule"]
    },
    {
      "id": "handler.form_on_create",
      "name": "Form OnCreateAtServer Handler",
      "name_ru": "Обработчик ПриСозданииНаСервере формы",
      "description": "Handler for form OnCreateAtServer event",
      "description_ru": "Обработчик события ПриСозданииНаСервере формы",
      "category": "form_handler",
      "template_code": "&НаСервере\nПроцедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)\n\t\n\t{{#if IsNewObject}}\n\tЕсли Объект.Ссылка.Пустая() Тогда\n\t\t// Инициализация для нового объекта\n\t\t${NewObjectCode}\n\tКонецЕсли;\n\t{{/if}}\n\t\n\t{{#if SetupVisibility}}\n\t// Настройка видимости элементов\n\t${VisibilityCode}\n\t{{/if}}\n\t\n\t{{#if FillLists}}\n\t// Заполнение списков выбора\n\t${ListsCode}\n\t{{/if}}\n\t\n\t${CustomCode}\n\t\nКонецПроцедуры",
      "placeholders": [
