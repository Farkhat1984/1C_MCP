        },
        {
          "name": "CustomCode",
          "display_name": "Дополнительный код",
          "type": "code_block",
          "required": false,
          "default_value": "// Ваш код здесь"
        }
      ],
      "tags": ["handler", "on_write", "ПриЗаписи", "событие"],
      "use_cases": ["Действия при записи", "Обновление связанных данных"],
      "applicable_module_types": ["ObjectModule"]
    },
    {
      "id": "handler.filling",
      "name": "Filling Event Handler",
      "name_ru": "Обработчик ОбработкаЗаполнения",
      "description": "Handler for Filling event",
      "description_ru": "Обработчик события ОбработкаЗаполнения",
      "category": "handler",
      "template_code": "Процедура ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)\n\t\n\tЕсли ТипЗнч(ДанныеЗаполнения) = Тип(\"${FillingDataType}\") Тогда\n\t\t\n\t\t${FillingCode}\n\t\t\n\tИначеЕсли ТипЗнч(ДанныеЗаполнения) = Тип(\"Структура\") Тогда\n\t\t\n\t\t// Заполнение из структуры\n\t\tЗаполнитьЗначенияСвойств(ЭтотОбъект, ДанныеЗаполнения);\n\t\t\n\tКонецЕсли;\n\t\n\t{{#if SetDefaults}}\n\t// Установка значений по умолчанию\n\t${DefaultsCode}\n\t{{/if}}\n\t\nКонецПроцедуры",
      "placeholders": [
        {
          "name": "FillingDataType",
          "display_name": "Тип данных заполнения",
          "description": "Тип данных для заполнения (например, СправочникСсылка.Контрагенты)",
          "type": "type_name",
          "required": true
        },
        {
          "name": "FillingCode",
          "display_name": "Код заполнения",
          "description": "Код заполнения из данных",
          "type": "code_block",
          "required": true
        },
        {
          "name": "SetDefaults",
          "display_name": "Установить умолчания",
          "type": "boolean",
          "required": false,
          "default_value": "false"
        },
        {
          "name": "DefaultsCode",
          "display_name": "Код умолчаний",
          "type": "code_block",
          "required": false
        }
      ],
      "tags": ["handler", "filling", "ОбработкаЗаполнения", "заполнение", "ввод на основании"],
      "use_cases": ["Ввод на основании", "Заполнение по умолчанию", "Копирование данных"],
      "applicable_module_types": ["ObjectModule"]
    },
    {
      "id": "handler.posting",
      "name": "Posting Event Handler",
      "name_ru": "Обработчик ОбработкаПроведения",
      "description": "Handler for Document Posting event",
      "description_ru": "Обработчик события ОбработкаПроведения документа",
      "category": "handler",
      "template_code": "Процедура ОбработкаПроведения(Отказ, РежимПроведения)\n\t\n\t// Инициализация движений\n\t${MovementsInit}\n\t\n\t// Запрос данных для движений\n\tЗапрос = Новый Запрос;\n\tЗапрос.Текст = \n\t\"${QueryText}\";\n\t\n\tЗапрос.УстановитьПараметр(\"Ссылка\", Ссылка);\n\t\n\tРезультат = Запрос.Выполнить();\n\tВыборка = Результат.Выбрать();\n\t\n\tПока Выборка.Следующий() Цикл\n\t\t\n\t\t${MovementCode}\n\t\t\nКонецЦикла;\n\t\nКонецПроцедуры",
      "placeholders": [
        {
          "name": "MovementsInit",
          "display_name": "Инициализация движений",
          "description": "Код инициализации наборов записей регистров",
          "type": "code_block",
          "required": true
        },
        {
          "name": "QueryText",
          "display_name": "Текст запроса",
          "description": "Запрос для получения данных движений",
          "type": "string",
          "required": true
        },
        {
          "name": "MovementCode",
          "display_name": "Код движений",
          "description": "Код формирования движений из выборки",
          "type": "code_block",
          "required": true
        }
      ],
      "tags": ["handler", "posting", "ОбработкаПроведения", "проведение", "документ", "движения"],
      "use_cases": ["Проведение документа", "Формирование движений"],
      "applicable_module_types": ["ObjectModule"],
      "examples": [
        {
          "description": "Простое проведение по регистру накопления",
          "values": {
            "MovementsInit": "Движения.ТоварыНаСкладах.Записывать = Истина;",
            "QueryText": "ВЫБРАТЬ\\n\\tТовары.Номенклатура,\\n\\tТовары.Количество,\\n\\tДок.Склад\\nИЗ\\n\\tДокумент.ПриходТовара.Товары КАК Товары\\n\\tВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПриходТовара КАК Док\\n\\tПО Товары.Ссылка = Док.Ссылка\\nГДЕ\\n\\tТовары.Ссылка = &Ссылка",
            "MovementCode": "Движение = Движения.ТоварыНаСкладах.Добавить();\\nДвижение.ВидДвижения = ВидДвиженияНакопления.Приход;\\nДвижение.Период = Дата;\\nДвижение.Номенклатура = Выборка.Номенклатура;\\nДвижение.Склад = Выборка.Склад;\\nДвижение.Количество = Выборка.Количество;"
          }
        }
      ]
    },
    {
